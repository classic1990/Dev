rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check admin status
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'duyclassic191@gmail.com';
    }

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userIdField) {
      return request.auth != null && request.auth.uid == resource.data[userIdField];
    }

    // Helper function to check if user is creating their own document
    function isCreatingOwn(userIdField) {
      return request.auth != null && request.auth.uid == request.resource.data[userIdField];
    }

    // Movies collection - public read access
    match /movies/{movieId} {
      // Public read access for movies
      allow read: if true;
      
      // Only admin can create or delete movies
      allow create, delete: if isAdmin();
      
      // Admin can update anything
      // Authenticated users can update only views, likes, and lastViewedAt
      allow update: if isAdmin() || (
        isAuthenticated() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['views', 'likes', 'likesCount', 'lastViewedAt', 'rating', 'comments'])
      );
    }

    // Users collection - users can only access their own data
    match /users/{userId} {
      // Users can read and write their own data
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      
      // Admin can read all user data (for moderation)
      allow read: if isAdmin();
      
      // No one can create user documents directly (they're created by auth triggers)
      allow create: if false;
    }

    // Watchlist collection - user-specific
    match /watchlist/{watchlistId} {
      // Users can read their own watchlist
      allow read: if isOwner('userId');
      
      // Users can create their own watchlist items
      allow create: if isCreatingOwn('userId') && 
        request.resource.data.keys().hasAll(['userId', 'movieId', 'addedAt']);
      
      // Users can update their own watchlist items
      allow update: if isOwner('userId') &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['watched', 'watchedAt', 'progress']);
      
      // Users can delete their own watchlist items
      allow delete: if isOwner('userId');
    }

    // Favorites collection - user-specific
    match /favorites/{favoriteId} {
      // Users can read their own favorites
      allow read: if isOwner('userId');
      
      // Users can create their own favorite items
      allow create: if isCreatingOwn('userId') && 
        request.resource.data.keys().hasAll(['userId', 'movieId', 'addedAt']);
      
      // Users can delete their own favorite items
      allow delete: if isOwner('userId');
      
      // No updates allowed for favorites (only create/delete)
      allow update: if false;
    }

    // History collection - user-specific viewing history
    match /history/{historyId} {
      // Users can read their own history
      allow read: if isOwner('userId');
      
      // Users can create their own history items
      allow create: if isCreatingOwn('userId') && 
        request.resource.data.keys().hasAll(['userId', 'movieId', 'watchedAt', 'duration']);
      
      // Users can update their own history (progress, completion)
      allow update: if isOwner('userId') &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['progress', 'completed', 'completedAt']);
      
      // Users can delete their own history
      allow delete: if isOwner('userId');
    }

    // Comments collection - public read, authenticated write
    match /comments/{commentId} {
      // Public read access for comments
      allow read: if true;
      
      // Authenticated users can create comments
      allow create: if isAuthenticated() && 
        request.resource.data.keys().hasAll(['userId', 'movieId', 'content', 'createdAt']) &&
        request.resource.data.content.size() > 0 &&
        request.resource.data.content.size() <= 500;
      
      // Users can update their own comments
      allow update: if isOwner('userId') &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['content', 'editedAt']) &&
        request.resource.data.content.size() > 0 &&
        request.resource.data.content.size() <= 500;
      
      // Users can delete their own comments, admin can delete any comment
      allow delete: if isOwner('userId') || isAdmin();
    }

    // Ratings collection - user-specific ratings
    match /ratings/{ratingId} {
      // Users can read their own ratings
      allow read: if isOwner('userId');
      
      // Users can create their own ratings
      allow create: if isCreatingOwn('userId') && 
        request.resource.data.keys().hasAll(['userId', 'movieId', 'rating', 'ratedAt']) &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 10;
      
      // Users can update their own ratings
      allow update: if isOwner('userId') &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['rating', 'ratedAt']) &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 10;
      
      // Users can delete their own ratings
      allow delete: if isOwner('userId');
    }

    // Admin-only collections
    match /admin/{document=**} {
      allow read, write, delete: if isAdmin();
    }

    // System logs and analytics - admin only
    match /logs/{document=**} {
      allow read, write: if isAdmin();
    }

    // Reports and moderation - admin only
    match /reports/{document=**} {
      allow read, write: if isAdmin();
    }

    // Security events - admin only
    match /security/{document=**} {
      allow read, write: if isAdmin();
    }

    // Deny access to any other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
